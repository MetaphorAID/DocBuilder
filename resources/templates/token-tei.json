{
	"name": "Token editor (tei)",
	"extension": "xml",
	"js": "token.js,token-tei.js",
	"css": "token.css",
	"chunks": {
		"<teiHeader>.*?(?:</teiHeader>)": ".header",
		"<head(?:| [^>]*)>.*?(?:</head>)": ".head",
		"<(lg|p)(?:| [^>]*)>.*?(?:</\\1>)": "p",
		"<annotations(?:/>|>.*?(?:</annotations>))": ".annotations"
	}
}